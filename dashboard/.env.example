# WorkOS AuthKit (https://dashboard.workos.com)
WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_test_...
# >= 32 chars; session cookie encryption. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKOS_COOKIE_PASSWORD=
# Must be registered under Redirects in the WorkOS dashboard.
WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Where the pipeline writes its artifacts (relative to dashboard/).
# Local dev: ../out. Remote deploy of the dashboard/ subtree: run
# `node stage-demo-data.mjs`, commit ./demo-data, and set this to ./demo-data.
LEGACYMIND_DATA_DIR=../out

# Public key the dashboard pins to verify certificate signatures. Use
# forward slashes (a backslash is a literal filename char on Linux hosts).
# Local dev default below. Remote deploy of the dashboard/ subtree cannot
# reach ../keys, so a copy is vendored here as ./trusted-key.pub.pem; set
# LEGACYMIND_TRUSTED_KEY=./trusted-key.pub.pem there. Both are the DEMO key
# (id 9b70a354) — swap for a real public key before any non-demo exposure.
LEGACYMIND_TRUSTED_KEY=../keys/legacymind-dev-ed25519.pub.pem
